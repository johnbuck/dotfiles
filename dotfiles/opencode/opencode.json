{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest"
  ],
  "compaction": {
    "auto": true,
    "prune": true
  },
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter (OmO)",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{file:~/.config/opencode/secrets/omo-openrouter-api-key}"
      },
      "models": {
        "gpt-5.4-nano": {
          "name": "GPT-5.4 Nano",
          "id": "openai/gpt-5.4-nano",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    },
    "llama-cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://__LLM_HOST__:8001/v1",
        "headers": {
          "Authorization": "Bearer {file:~/.config/opencode/secrets/llama-cpp-api-key}"
        }
      },
      "models": {
        "qwen3-coder-30b": {
          "name": "Qwen 3 Coder 30B",
          "id": "qwen3-coder-30b-q4km",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "qwen3-32b": {
          "name": "Qwen 3 32B",
          "id": "qwen3-32b-q4km",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "deepseek-r1-distill-32b": {
          "name": "DeepSeek R1 Distill 32B",
          "id": "deepseek-r1-distill-qwen-32b-q4km",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "codestral-22b": {
          "name": "Codestral 22B",
          "id": "codestral-22b-q4km",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "glm-4v-flash": {
          "name": "GLM-4.6V Flash (Vision)",
          "id": "GLM-4.6V-Flash-Q8_0",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "qwen3-0.6b": {
          "name": "Qwen 3 0.6B (Fast)",
          "id": "qwen3-0.6b-q4km",
          "limit": {
            "context": 32768,
            "output": 4096
          }
        },
        "qwen3.5-35b-a3b": {
          "name": "Qwen 3.5 35B A3B (MoE)",
          "id": "qwen3.5-35b-a3b-q4km",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "qwen3.5-27b": {
          "name": "Qwen 3.5 27B",
          "id": "qwen3.5-27b-q4km",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "qwen3-30b-a3b-thinking": {
          "name": "Qwen 3 30B A3B Thinking",
          "id": "qwen3-30b-a3b-thinking-2507-q4km",
          "limit": {
            "context": 65536,
            "output": 8192
          }
        },
        "gemma-4-31b": {
          "name": "Gemma 4 31B",
          "id": "gemma-4-31B-it-UD-Q4_K_XL",
          "limit": {
            "context": 196608,
            "output": 8192
          }
        },
        "qwen3.6-35b-a3b": {
          "name": "Qwen 3.6 35B A3B",
          "id": "Qwen3.6-35B-A3B-UD-IQ4_NL_XL",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  },
  "mcp": {
    "memory": {
      "type": "remote",
      "url": "http://__MCP_HOST__:8404/mcp",
      "enabled": true
    },
    "sequential-thinking": {
      "type": "remote",
      "url": "http://__MCP_HOST__:8406/mcp",
      "enabled": true
    },
    "uptime-kuma": {
      "type": "remote",
      "url": "http://__MCP_HOST__:8403/mcp",
      "enabled": true
    },
    "todoist": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@greirson/mcp-todoist"
      ],
      "environment": {
        "TODOIST_API_TOKEN": "{file:~/.config/opencode/secrets/todoist-api-key}",
        "DRYRUN": "true"
      },
      "enabled": true
    },
    "n8n-mcp": {
      "type": "remote",
      "url": "http://__MCP_HOST__:8402/mcp",
      "enabled": true
    },
    "ynab": {
      "type": "remote",
      "url": "http://__MCP_HOST__:8400/mcp",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/secrets/ynab-mcp-bearer}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "chromium"
      ],
      "enabled": true
    },
    "excalidraw-gen": {
      "type": "remote",
      "url": "http://__MCP_HOST__:8401/mcp",
      "headers": {
        "Authorization": "Bearer {file:~/.config/opencode/secrets/excalidraw-gen-bearer}"
      },
      "enabled": true
    },
    "remotion": {
      "type": "remote",
      "url": "http://__MCP_HOST__:8405/mcp",
      "enabled": true
    }
  },
  "permission": {
    "doom_loop": "ask",
    "external_directory": {
      "*": "ask",
      "~/projects/**": "allow",
      "~/Docker/**": "allow",
      "~/scripts/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "edit": {
      "*": "ask",
      "~/projects/**": "allow",
      "~/Docker/**": "allow",
      "~/scripts/**": "allow",
      "~/.config/opencode/**": "allow"
    },
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git status": "allow",
      "git diff *": "allow",
      "git diff": "allow",
      "git log *": "allow",
      "git log": "allow",
      "git branch *": "allow",
      "git branch": "allow",
      "git remote *": "allow",
      "git show *": "allow",
      "git rev-parse *": "allow",
      "git config *": "allow",
      "git ls-files *": "allow",
      "git ls-files": "allow",
      "git add *": "allow",
      "git add": "allow",
      "git commit *": "allow",
      "git stash *": "allow",
      "git checkout *": "allow",
      "git switch *": "allow",
      "git merge *": "ask",
      "git rebase *": "ask",
      "git push *": "ask",
      "git push --force *": "deny",
      "git reset --hard *": "deny",
      "ls *": "allow",
      "ls": "allow",
      "pwd": "allow",
      "pwd *": "allow",
      "which *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "wc *": "allow",
      "du *": "allow",
      "df *": "allow",
      "realpath *": "allow",
      "dirname *": "allow",
      "basename *": "allow",
      "readlink *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "less *": "allow",
      "bat *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "fd *": "allow",
      "fzf *": "allow",
      "tree *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "xargs *": "allow",
      "docker ps *": "allow",
      "docker ps": "allow",
      "docker logs *": "allow",
      "docker inspect *": "allow",
      "docker images *": "allow",
      "docker images": "allow",
      "docker network ls *": "allow",
      "docker network ls": "allow",
      "docker network inspect *": "allow",
      "docker volume ls *": "allow",
      "docker volume ls": "allow",
      "docker volume inspect *": "allow",
      "docker compose ps *": "allow",
      "docker compose ps": "allow",
      "docker compose logs *": "allow",
      "docker compose config *": "allow",
      "docker run *": "ask",
      "docker exec *": "ask",
      "docker stop *": "ask",
      "docker start *": "ask",
      "docker restart *": "ask",
      "docker rm *": "ask",
      "docker compose up *": "ask",
      "docker compose down *": "ask",
      "docker compose restart *": "ask",
      "systemctl status *": "allow",
      "systemctl --user status *": "allow",
      "systemctl --user list-timers *": "allow",
      "systemctl --user list-timers": "allow",
      "systemctl list-timers *": "allow",
      "systemctl is-active *": "allow",
      "systemctl is-enabled *": "allow",
      "systemctl show *": "allow",
      "journalctl *": "allow",
      "systemctl start *": "ask",
      "systemctl stop *": "ask",
      "systemctl restart *": "ask",
      "systemctl enable *": "ask",
      "systemctl disable *": "ask",
      "systemctl --user start *": "ask",
      "systemctl --user stop *": "ask",
      "systemctl --user restart *": "ask",
      "curl *": "allow",
      "wget *": "allow",
      "curl * | bash": "deny",
      "curl * | sh": "deny",
      "wget * | bash": "deny",
      "wget * | sh": "deny",
      "npm list *": "allow",
      "npm ls *": "allow",
      "npm outdated *": "allow",
      "npm view *": "allow",
      "npm install *": "allow",
      "npm i *": "allow",
      "npm ci *": "allow",
      "npm run *": "allow",
      "npm test *": "allow",
      "npm build *": "allow",
      "npm publish *": "ask",
      "npx *": "allow",
      "bun *": "allow",
      "yarn *": "allow",
      "pnpm *": "allow",
      "ssh *": "allow",
      "scp *": "allow",
      "rsync *": "allow",
      "gh *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "pip *": "allow",
      "pip3 *": "allow",
      "uv *": "allow",
      "go *": "allow",
      "cargo *": "allow",
      "rustc *": "allow",
      "make *": "allow",
      "cmake *": "allow",
      "ninja *": "allow",
      "restic *": "allow",
      "rclone *": "allow",
      "mv *": "ask",
      "cp *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "chmod *": "ask",
      "chown *": "ask",
      "chmod 777 *": "deny",
      "rm *": "ask",
      "rm -rf /*": "deny",
      "rm -rf /home/*": "deny",
      "rm -rf ~/*": "deny",
      "rm -r /*": "deny",
      "sudo *": "ask",
      "su *": "deny",
      "dd *": "deny",
      "mkfs *": "deny",
      "fdisk *": "deny",
      "parted *": "deny",
      "mount *": "ask",
      "umount *": "ask",
      "env": "allow",
      "env *": "allow",
      "printenv *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "date *": "allow",
      "date": "allow",
      "uptime *": "allow",
      "uptime": "allow",
      "uname *": "allow",
      "hostname *": "allow",
      "hostname": "allow",
      "whoami": "allow",
      "id": "allow",
      "id *": "allow",
      "groups *": "allow"
    }
  }
}
