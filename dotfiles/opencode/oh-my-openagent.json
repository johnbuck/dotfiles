  "agents": {
    "sisyphus": {
      "model": "openrouter/moonshotai/kimi-k2.6"
    },
    "hephaestus": {
      "model": "openrouter/deepseek/deepseek-v4-pro"
    },
    "prometheus": {
      "model": "zai-coding-plan/glm-5.1"
    },
    "atlas": {
      "model": "openrouter/moonshotai/kimi-k2.6"
    },
    "oracle": {
      "model": "zai-coding-plan/glm-5.1"
    },
    "momus": {
      "model": "openrouter/deepseek/deepseek-v4-pro"
    },
    "metis": {
      "model": "openrouter/moonshotai/kimi-k2.6"
    },
    "librarian": {
      "model": "zai-coding-plan/glm-4.5-air"
    },
    "explore": {
      "model": "zai-coding-plan/glm-4.5-air"
    },
    "sisyphus-junior": {
      "model": "openrouter/moonshotai/kimi-k2.6"
