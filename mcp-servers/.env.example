# Copy to .env and fill in. Only n8n-mcp and uptime-kuma-mcp read these;
# memory / sequential-thinking / remotion need nothing.
# Confirm exact variable names against each package's npm README.

# n8n-mcp  -> https://www.npmjs.com/package/n8n-mcp
N8N_API_URL=
N8N_API_KEY=

# uptime-kuma  -> https://www.npmjs.com/package/@davidfuchs/mcp-uptime-kuma
UPTIME_KUMA_URL=
UPTIME_KUMA_USERNAME=
UPTIME_KUMA_PASSWORD=
