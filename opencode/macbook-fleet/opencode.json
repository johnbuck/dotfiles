{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/deepseek-v4-pro",
  "compaction": { "auto": true, "prune": true },
  "instructions": [
    "~/.config/opencode/AGENTS.md",
    "~/.config/opencode/skills/pnk-preferences.yaml"
  ],
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:__OR_KEY__}"
      },
      "models": {
        "deepseek-v4-flash": { "name": "DeepSeek V4 Flash", "id": "deepseek/deepseek-v4-flash", "limit": { "context": 1048576, "output": 16384 } },
        "deepseek-v4-pro": { "name": "DeepSeek V4 Pro", "id": "deepseek/deepseek-v4-pro", "limit": { "context": 1048576, "output": 16384 } },
        "kimi-k2.6": { "name": "Kimi K2.6", "id": "moonshotai/kimi-k2.6", "limit": { "context": 262144, "output": 16384 } },
        "kimi-k2.7-code": { "name": "Kimi K2.7 Code", "id": "moonshotai/kimi-k2.7-code", "limit": { "context": 262144, "output": 16384 } },
        "gpt-5.4-nano": { "name": "GPT-5.4 Nano", "id": "openai/gpt-5.4-nano", "limit": { "context": 131072, "output": 8192 } }
      }
    },
    "llama-cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://__LLM_HOST__/v1",
        "headers": { "Authorization": "Bearer {env:LLAMA_CPP_API_KEY}" }
      },
      "models": {
        "qwen3-coder-30b": { "name": "Qwen3 Coder 30B", "id": "qwen3-coder-30b-q4km", "limit": { "context": 65536, "output": 8192 } },
        "qwen3-32b": { "name": "Qwen3 32B", "id": "qwen3-32b-q4km", "limit": { "context": 65536, "output": 8192 } }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest", "--browser", "chromium"],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": ["__SERENA__", "start-mcp-server", "--context", "ide-assistant", "--enable-web-dashboard", "false", "--enable-gui-log-window", "false"],
      "enabled": true
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny", "*.env.*": "deny", "*.env.example": "allow",
      "**/.ssh/**": "deny", ".ssh/**": "deny",
      "**/.config/opencode/infisical/**": "deny", ".config/opencode/infisical/**": "deny",
      "**/.aws/**": "deny", "**/.gnupg/**": "deny", "**/.kube/**": "deny",
      "**/.config/gcloud/**": "deny", "**/.netrc": "deny", "**/.npmrc": "deny",
      "**/.docker/config.json": "deny", "**/.git-credentials": "deny",
      "**/id_rsa": "deny", "**/id_ed25519": "deny", "**/id_ecdsa": "deny", "**/id_dsa": "deny",
      "**/*.p12": "deny", "**/*.pfx": "deny", "**/.pgpass": "deny",
      "**/credentials.json": "deny", "**/auth.json": "deny", "**/*.pub": "allow"
    },
    "edit": {
      "*": "allow",
      "**/.ssh/**": "deny", ".ssh/**": "deny",
      "**/.config/opencode/**": "deny", ".config/opencode/**": "deny",
      "**/.bashrc": "deny", "**/.zshrc": "deny", "**/.profile": "deny", "**/.config/fish/**": "deny",
      "**/.aws/**": "deny", "**/.gnupg/**": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": {
      "*": "allow",
      "**/.config/opencode/infisical/**": "deny", "**/.config/opencode/plugins/**": "deny",
      "**/.config/opencode/opencode.json": "deny", "**/.config/opencode/AGENTS.md": "deny",
      "**/.ssh/**": "deny", "**/.aws/**": "deny", "**/.gnupg/**": "deny", "**/.kube/**": "deny",
      "**/.config/gcloud/**": "deny", "**/.netrc": "deny", "**/.git-credentials": "deny"
    },
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "skill": "allow",
    "task": "allow",
    "todowrite": "allow",
    "question": "allow",
    "doom_loop": "ask",
    "bash": {
      "*": "allow",
      "dd *": "deny", "mkfs*": "deny", "wipefs *": "deny", "blkdiscard *": "deny", "shred *": "deny",
      "* | sh": "deny", "* | bash": "deny",
      "chmod 777 *": "deny", "chmod -R 777 *": "deny"
    }
  }
}
