{
  "auth": {
    "cooldowns": {
      "overloadedBackoffMs": 5000,
      "overloadedProfileRotations": 1,
      "rateLimitedProfileRotations": 1,
      "failureWindowHours": 0.5,
      "billingBackoffHours": 1,
      "authPermanentBackoffMinutes": 5
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "glm/glm-5.1",
        "fallbacks": [
          "openrouter/deepseek/deepseek-v4-pro",
          "openrouter/z-ai/glm-5.1",
          "openrouter/deepseek/deepseek-v4-flash",
          "llama/Qwen3.6-35B-A3B-UD-IQ4_NL_XL"
        ]
      },
      "imageGenerationModel": {
        "primary": "comfy/workflow"
      },
      "subagents": {
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5,
        "maxConcurrent": 8
      },
      "heartbeat": {
        "every": "30m",
        "lightContext": true,
        "isolatedSession": true
      },
      "compaction": {
        "postCompactionSections": [
          "Session Startup",
          "Red Lines",
          "Coding Principles"
        ]
      }
    },
    "list": [
      {
        "id": "main",
        "heartbeat": {
          "every": "30m",
          "lightContext": false,
          "isolatedSession": false
        }
      },
      {
        "id": "doug",
        "name": "doug",
        "workspace": "/home/node/.openclaw/agents/doug/workspace",
        "agentDir": "/home/node/.openclaw/agents/doug/agent",
        "heartbeat": {
          "every": "30m",
          "lightContext": true,
          "isolatedSession": true
        }
      }
    ]
  },
